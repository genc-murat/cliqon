{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cliqon",
  "version": "0.6.0",
  "identifier": "com.murat.cliqon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cliqon",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MDg3OUREODE0NUI0NkMKUldSc3RFV0IzWGtJZGhrRUYvS3NPa1dYcmhrc3ZGNXRGazZ1cXMveHNXWnVDV28rWkhhNlBXa1IK",
      "endpoints": [
        "https://github.com/genc-murat/cliqon/releases/latest/download/latest.json"
      ]
    }
  }
}